{
  "name": "networked-players-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "validate:data": "node scripts/build-rounds.mjs --check",
    "build": "npm run validate:data && astro build",
    "preview": "astro preview",
    "check": "npm run validate:data && astro check && astro build",
    "test:smoke": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "astro build && wrangler deploy"
  },
  "dependencies": {
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "1.55.0",
    "@types/node": "^22.20.0",
    "prettier": "3.9.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
