---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpinningRecord from '../components/SpinningRecord.astro';
import AlbumCard from '../components/AlbumCard.astro';
import site from '../data/site.json';
import type { ChallengeV2 } from '../data/challenge';
import challengeData from '../../public/data/challenge.v2.json';

const { hero, focus } = site;

const challenge = challengeData as ChallengeV2;
const connectedAlbumIds = new Set(
  challenge.paths.flatMap((p) => [p.from_album_id, p.to_album_id]),
);
const albums = challenge.albums.filter((album) => connectedAlbumIds.has(album.id));
---

<BaseLayout>
  <section class="hero hero--split shell">
    <div>
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1>{hero.headline}</h1>
      <p class="lede">{hero.lede}</p>
      <div class="hero-actions">
        <a class="button primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
        <a class="button" href={hero.ctaSecondary.href}>{hero.ctaSecondary.label}</a>
      </div>
    </div>
    <SpinningRecord />
  </section>

  <section class="section shell" id="albums" aria-labelledby="albums-title">
    <div class="section-heading">
      <p class="eyebrow">Start here</p>
      <h2 id="albums-title">Albums</h2>
      <p class="lede">
        Open an album to find who connects it to another — a shared session player, producer, or
        engineer, documented credit by credit.
      </p>
    </div>
    <div class="album-grid">
      {albums.map((album) => <AlbumCard album={album} />)}
    </div>
  </section>

  <section class="section shell" aria-labelledby="how-title">
    <div class="section-heading">
      <p class="eyebrow">{focus.eyebrow}</p>
      <h2 id="how-title">{focus.heading}</h2>
      <p class="lede">{focus.lede}</p>
    </div>
    <div class="feature-grid">
      {
        focus.cards.map((card) => (
          <article class="feature-card" data-tone={card.tone}>
            <span class="kicker">{card.kicker}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section shell" aria-labelledby="state-title">
    <div class="section-heading">
      <p class="eyebrow">Honest status</p>
      <h2 id="state-title">An early build, not a finished product.</h2>
      <p class="lede">
        The album grid above and its evidence viewer now run on real, Discogs monthly-dump-derived
        data (snapshot {challenge.provenance.snapshot_date}) — {albums.length} albums connected by{' '}
        {challenge.paths.length} documented credit paths, not a synthetic placeholder. The album
        list itself is an editorial selection, not a ranking. <a href="/guess/">Connection Guesser</a>{' '}
        and <a href="/daily/">Connection of the Day</a> run on the same real snapshot. The
        connections demo (linked below) is an earlier, smaller API-sourced slice, kept during the
        transition rather than because it's still the primary real dataset.
      </p>
    </div>
    <div class="hero-actions" style="margin-top:0">
      <a class="button primary" href="/guess/">Play Connection Guesser</a>
      <a class="button" href="/about/">Read the full picture</a>
    </div>
  </section>
</BaseLayout>
