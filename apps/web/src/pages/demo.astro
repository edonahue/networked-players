---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidencePanel from '../components/EvidencePanel.astro';
import { buildHopViews } from '../data/evidence';
import type { Challenge, Release } from '../data/challenge';
import challengeData from '../../public/data/challenge.v1.json';

// The same versioned artifact that is served at /data/challenge.v1.json. The
// demo is static-first: paths are rendered at build time and need no backend.
const challenge = challengeData as Challenge;
const { provenance, releases, artists, paths } = challenge;

const nameById = new Map(artists.map((a) => [a.artist_id, a.name]));
const releaseById = new Map(releases.map((r) => [r.release_id, r]));
const displayName = (id: number) => nameById.get(id) ?? `Artist ${id}`;

// Deduplicated cover thumbnails across a path's releases, in hop order.
const coverStrip = (path: (typeof paths)[number]) => {
  const seen = new Set<number>();
  return path.hops
    .map((hop) => releaseById.get(hop.release_id))
    .filter((release): release is Release => release !== undefined)
    .filter((release) => {
      if (seen.has(release.release_id) || release.images.length === 0) return false;
      seen.add(release.release_id);
      return true;
    })
    .map((release) => release.images[0].uri150);
};

const description =
  'A static, client-side proof of concept: documented paths between real artists, with the credit evidence and cover art shown at every hop.';
---

<BaseLayout title="Connections demo" description={description}>
  <section class="prose shell" style="padding-bottom:24px">
    <p class="eyebrow">Connections demo</p>
    <h1>Documented paths, with their evidence.</h1>
    <p class="lede">
      Pick a path below. Each hop links two artists who are credited on the same release, and shows
      the credit rows that prove it — scope, role text, and linked identity — exactly as the
      ingestion pipeline records them.
    </p>
  </section>

  <section class="shell" aria-label="Connections demo" style="padding-bottom:80px">
    <p class="data-banner">
      <span aria-hidden="true">◉</span>
      <span>
        <strong>Real Discogs data, a curated subset.</strong> These {releases.length} releases and{' '}
        {paths.length} paths are real, fetched from the Discogs API — cover art is hotlinked
        directly from Discogs' own CDN, never downloaded or rehosted. This is a small slice, not a
        reconstruction of any private collection; see the provenance note below for details.
      </span>
    </p>

    <div class="path-picker" role="group" aria-label="Choose a path">
      {
        paths.map((path, index) => (
          <button type="button" data-path-target={path.id} aria-pressed={index === 0 ? 'true' : 'false'}>
            {path.label}
          </button>
        ))
      }
    </div>

    {
      paths.map((path, index) => (
        <EvidencePanel
          class="path-card"
          pathId={path.id}
          hidden={index !== 0}
          hops={buildHopViews(path.hops, releases, artists, { covers: true })}
        >
          <h3 class="path-card__summary">
            {displayName(path.from_artist_id)}
            <span class="arrow" aria-hidden="true">→</span>
            {displayName(path.to_artist_id)}
          </h3>
          <p class="path-card__sub">{path.description}</p>
          {coverStrip(path).length > 0 && (
            <div class="path-card__covers" aria-hidden="true">
              {coverStrip(path).map((uri) => (
                <img
                  class="cover-thumb"
                  src={uri}
                  width="56"
                  height="56"
                  loading="lazy"
                  alt=""
                  data-art-fallback="hide"
                />
              ))}
            </div>
          )}
        </EvidencePanel>
      ))
    }

    <section class="provenance" aria-label="Provenance">
      <p>
        <strong>How to read this:</strong> an edge means two artists are credited on the same
        release or track — documented collaboration, never inferred influence. Linked identities
        (with an <code>artist_id</code>) can be path nodes; non-linked names are kept as evidence
        but never become playable identities.
      </p>
      <dl>
        <dt>Source</dt>
        <dd>{provenance.source}</dd>
        <dt>License</dt>
        <dd>{provenance.license}</dd>
        <dt>Snapshot</dt>
        <dd>{provenance.snapshot_date}</dd>
        <dt>Parser</dt>
        <dd>networked-players-catalog {provenance.catalog_parser_version}</dd>
        <dt>Schema</dt>
        <dd>credits schema v{provenance.catalog_schema_version}</dd>
        <dt>Artifact</dt>
        <dd><a href="/data/challenge.v1.json">/data/challenge.v1.json</a></dd>
      </dl>
      <p style="margin-top:12px">{provenance.note}</p>
    </section>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const buttons = Array.from(document.querySelectorAll('[data-path-target]'));
    const cards = Array.from(document.querySelectorAll('.path-card'));
    if (!buttons.length) return;
    const show = (id) => {
      cards.forEach((card) => {
        card.toggleAttribute('hidden', card.getAttribute('data-path-id') !== id);
      });
      buttons.forEach((btn) => {
        btn.setAttribute('aria-pressed', String(btn.getAttribute('data-path-target') === id));
      });
    };
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => show(btn.getAttribute('data-path-target')));
    });
  })();
</script>
