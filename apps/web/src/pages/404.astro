---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" noIndex={true}>
  <section class="hero shell">
    <p class="eyebrow">404 · No matching credit</p>
    <h1>That path isn't in the record.</h1>
    <p class="lede">The page may have moved, or never been pressed. Head back to the start.</p>
    <div class="hero-actions">
      <a class="button primary" href="/">Return home</a>
      <a class="button" href="/demo/">Try the demo</a>
    </div>
  </section>
</BaseLayout>
