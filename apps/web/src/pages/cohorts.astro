---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { PlayableCohortManifest } from '../data/cohort';
import { cohortArtifacts } from '../data/cohortArtifacts';
import manifestData from '../../public/data/cohorts/index.json';

const manifest = manifestData as PlayableCohortManifest;

// Every manifest entry must have a matching static import in
// cohortArtifacts.ts -- a broken link in the list below would otherwise go
// unnoticed until someone opened it. The reverse direction (an orphaned
// cohortArtifacts entry with no manifest listing) has no runtime consequence
// for this page, so it's covered by apps/web/tests/cohort-manifest.spec.ts
// instead, not here.
const entries = manifest.cohorts.map((entry) => {
  const cohort = cohortArtifacts[entry.cohort_id];
  if (!cohort) {
    throw new Error(
      `Manifest entry ${entry.cohort_id} has no matching static import in cohortArtifacts.ts`,
    );
  }
  return { entry, pairCount: cohort.pairs.length };
});

const description =
  'Reviewed playable cohorts: open one to guess the documented connection between two albums, then reveal the credit evidence.';
---

<BaseLayout title="Reviewed cohorts" description={description}>
  <section class="shell" style="padding-top:40px">
    <p class="eyebrow" style="margin-bottom:6px">Reviewed cohorts</p>
    <h1 style="font-size:clamp(1.8rem,4vw,2.6rem)">Browse reviewed cohorts</h1>
    <p class="lede" style="margin-top:6px">
      {description}
    </p>

    <ul style="margin-top:16px">
      {
        entries.map(({ entry, pairCount }) => (
          <li style="margin-bottom:12px">
            <strong>{entry.title}</strong> <span class="tag">{entry.status}</span>
            <p class="path-card__sub">
              {entry.description} · {pairCount} pair{pairCount === 1 ? '' : 's'}
            </p>
            <a href={`/cohorts/${entry.cohort_id}/`}>Open cohort</a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
