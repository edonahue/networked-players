---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GameStage from '../../../components/GameStage.astro';

// The daily deals one frozen, real one-hop round per LOCAL calendar date
// (each browser's own midnight, not UTC -- game/localDate.ts) -- the same
// scheduled connection for everyone on that date label, resolved from a
// committed, append-only manifest (docs/WEB_PRODUCT_PLAN.md §5; ADR 0043's
// corrective-slice-4.6 and -5.1 addenda; see game/dailyManifest.ts).
// game/flagship.ts fetches the full round pool at runtime (shared browser
// cache with /play/connection/) plus daily-manifest.v1.json, and verifies
// the complete pairing (schema versions, mode, all three catalog/pool/
// artifact versions, and the resolved round's published content) before
// dealing it.
const description =
  'Connection of the Day: one frozen connection per local calendar day, resolved from a committed schedule. Keep a streak; share your grooves, never the answer.';
---

<BaseLayout title="Connection of the Day" description={description}>
  <section class="prose shell" style="padding-bottom:0">
    <p class="eyebrow">Connection of the Day</p>
    <h1 style="font-size:clamp(1.9rem,4.5vw,2.8rem)">
      One connection. Everyone digs today.
    </h1>
  </section>

  <GameStage label="Connection of the Day round" />

  <section class="prose shell" style="padding-top:28px;padding-bottom:72px">
    <p class="lede" style="font-size:0.95rem">
      Each day's round is fixed in a committed schedule — the same connection for
      everyone on that calendar date, resolved at your own local midnight. No account,
      no server; your streak stays on this device. The share text carries the date and
      your grooves, never a name. Every connection is a documented credit: participation
      on a recording, nothing more.
    </p>
  </section>
</BaseLayout>

<script>
  import { initFlagship } from '../../../game/flagship';
  initFlagship({ daily: true });
</script>
