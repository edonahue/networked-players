---
// Redirect stub: album detail pages moved from /play/<id>/ to /albums/<id>/
// (docs/WEB_PRODUCT_PLAN.md §6) so the /play/ namespace belongs to the game
// modes. Old URLs keep working via an instant meta refresh plus a visible
// link; the canonical points at the new home and the stub is noindex.
import type { ChallengeV2 } from '../../data/challenge';
import challengeData from '../../../public/data/challenge.v2.json';

export function getStaticPaths() {
  const data = challengeData as ChallengeV2;
  const connectedAlbumIds = new Set<string>();
  for (const path of data.paths) {
    connectedAlbumIds.add(path.from_album_id);
    connectedAlbumIds.add(path.to_album_id);
  }
  return data.albums
    .filter((album) => connectedAlbumIds.has(album.id))
    .map((album) => ({ params: { album: album.id }, props: { title: album.title } }));
}

interface Props {
  title: string;
}

const { album } = Astro.params;
const { title } = Astro.props;
const target = `/albums/${album}/`;
const canonical = new URL(target, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`Moved: ${title}`}</title>
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
  </head>
  <body>
    <p>
      This page moved to <a href={target} data-testid="redirect-target">{canonical.toString()}</a>.
    </p>
  </body>
</html>
