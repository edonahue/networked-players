---
import EvidencePanel from './EvidencePanel.astro';
import type { PanelHop } from '../data/evidence';
import type { CohortAlbum, CohortPair } from '../data/cohort';

interface Props {
  pair: CohortPair;
  albums: CohortAlbum[];
  revealId: string;
}

const { pair, albums, revealId } = Astro.props;
const albumById = new Map(albums.map((a) => [a.id, a]));
const albumA = albumById.get(pair.album_a_id);
const albumB = albumById.get(pair.album_b_id);
const hasWarnings = pair.warnings.length > 0;

const FLAG_LABELS: Record<string, string> = {
  co_billed_release_artists: 'co-billed release artists',
  performer_credit: 'performer credit',
  non_performer_only: 'non-performer credit only (flagged)',
  placeholder_artist_hop: 'involves a placeholder identity',
};

const flagLabels = (flags: string[]) =>
  flags.map((f) => FLAG_LABELS[f] ?? f).join(', ');

// The playable-cohort contract ships hop ids and quality flags, not
// per-credit rows — the panel renders the flags line in place of a table.
const artistName = (id: number) =>
  pair.artist_a_id === id && albumA
    ? albumA.artist
    : pair.artist_b_id === id && albumB
      ? albumB.artist
      : `artist ${id}`;

const hopViews: PanelHop[] = pair.hops.map((hop, index) => ({
  index: index + 1,
  aName: artistName(hop.artist_a_id),
  bName: artistName(hop.artist_b_id),
  release: {
    ref: String(hop.release_id),
    title: `release ${hop.release_id}`,
    released: null,
    country: null,
    sourceUrl: null,
  },
  coverUri: null,
  rows: [],
  nonLinked: [],
  flagsLine: `Quality: ${flagLabels(hop.quality_flags)}. Per the playable-cohort contract, no per-credit rows ship here — the reviewed connection itself is the claim.`,
}));
---

<article class="cohort-pair" data-cohort-pair data-reveal-scope>
  <div class="cohort-pair__albums">
    <div class="cohort-album">
      <span class="cohort-album__placeholder album-card__placeholder" aria-hidden="true">
        <span class="album-card__placeholder-disc" />
      </span>
      <div class="cohort-album__text">
        <p class="cohort-album__title">{albumA?.title ?? pair.album_a_id}</p>
        {
          albumA && (
            <p class="cohort-album__meta">
              {albumA.artist}
              {albumA.year ? ` · ${albumA.year}` : ''}
            </p>
          )
        }
      </div>
    </div>
    <span class="cohort-pair__arrow" aria-hidden="true">→</span>
    <div class="cohort-album">
      <span class="cohort-album__placeholder album-card__placeholder" aria-hidden="true">
        <span class="album-card__placeholder-disc" />
      </span>
      <div class="cohort-album__text">
        <p class="cohort-album__title">{albumB?.title ?? pair.album_b_id}</p>
        {
          albumB && (
            <p class="cohort-album__meta">
              {albumB.artist}
              {albumB.year ? ` · ${albumB.year}` : ''}
            </p>
          )
        }
      </div>
    </div>
  </div>

  <div class="cohort-pair__meta">
    <span class="tag tag--difficulty">{pair.difficulty}</span>
    <span class="tag">{pair.hop_count} hop{pair.hop_count === 1 ? '' : 's'}</span>
    {
      hasWarnings ? (
        <span class="tag tag--warning">
          {pair.warnings.length} warning{pair.warnings.length === 1 ? '' : 's'}
        </span>
      ) : (
        <span class="tag tag--clean">reviewed clean</span>
      )
    }
    <button
      type="button"
      class="cohort-pair__reveal"
      data-reveal-button
      data-reveal-label="Reveal"
      data-hide-label="Hide"
      aria-expanded="false"
      aria-controls={revealId}
    >
      Reveal
    </button>
  </div>

  <div
    id={revealId}
    class="cohort-pair__hops"
    data-guess-target
    data-revealed="false"
    hidden
  >
    <EvidencePanel hops={hopViews} />
  </div>
</article>
