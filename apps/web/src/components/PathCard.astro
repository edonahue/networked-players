---
import type { Artist, Credit, Path, Release } from '../data/challenge';

interface Props {
  path: Path;
  releases: Release[];
  artists: Artist[];
  hidden?: boolean;
}

const { path, releases, artists, hidden = false } = Astro.props;

const releaseById = new Map(releases.map((r) => [r.release_id, r]));
const nameById = new Map(artists.map((a) => [a.artist_id, a.name]));

const displayName = (id: number) => nameById.get(id) ?? `Artist ${id}`;
const scopeLabel: Record<Credit['credit_scope'], string> = {
  release_artist: 'release artist',
  release_credit: 'release credit',
  track_artist: 'track artist',
  track_credit: 'track credit',
};

// Deduplicated cover thumbnails across every release in this path, in hop order.
const pathReleases = path.hops
  .map((hop) => releaseById.get(hop.release_id))
  .filter((release): release is Release => release !== undefined);
const seenReleaseIds = new Set<number>();
const coverReleases = pathReleases.filter((release) => {
  if (seenReleaseIds.has(release.release_id) || release.images.length === 0) return false;
  seenReleaseIds.add(release.release_id);
  return true;
});
---

<article class="path-card" data-path-id={path.id} hidden={hidden}>
  <h3 class="path-card__summary">
    {displayName(path.from_artist_id)}
    <span class="arrow" aria-hidden="true">→</span>
    {displayName(path.to_artist_id)}
  </h3>
  <p class="path-card__sub">{path.description}</p>

  {
    coverReleases.length > 0 && (
      <div class="path-card__covers" aria-hidden="true">
        {coverReleases.map((release) => (
          <img
            class="cover-thumb"
            src={release.images[0].uri150}
            width="56"
            height="56"
            loading="lazy"
            alt=""
          />
        ))}
      </div>
    )
  }

  {
    path.hops.map((hop, index) => {
      const release = releaseById.get(hop.release_id);
      if (!release) return null;
      // Evidence = the credit rows that place both endpoints on this release.
      const endpoints = [hop.artist_a_id, hop.artist_b_id];
      const evidence = release.credits.filter(
        (c) => c.artist_id !== null && endpoints.includes(c.artist_id),
      );
      // Non-linked contributors are retained as evidence but are never nodes.
      const nonLinked = release.credits.filter((c) => !c.is_linked);
      const cover = release.images[0];
      return (
        <div class="hop">
          <div class="hop__head">
            {cover && (
              <img
                class="hop__cover"
                src={cover.uri150}
                width="64"
                height="64"
                loading="lazy"
                alt={`Cover art for ${release.title}`}
              />
            )}
            <div class="hop__head-text">
              <p class="hop__title">
                Hop {index + 1}: {displayName(hop.artist_a_id)} and {displayName(hop.artist_b_id)}
              </p>
              <p class="hop__release">
                both credited on <strong>{release.title}</strong>
                {release.released ? ` (${release.released}` : ''}
                {release.released && release.country
                  ? `, ${release.country})`
                  : release.released
                    ? ')'
                    : ''}
                {' · '}
                <a href={release.source_url} rel="nofollow noopener">source</a>
              </p>
            </div>
          </div>
          <div class="evidence">
            <table>
              <caption>Release {release.release_id} · evidence</caption>
              <thead>
                <tr>
                  <th scope="col">Credited as</th>
                  <th scope="col">Scope</th>
                  <th scope="col">Role</th>
                  <th scope="col">Identity</th>
                </tr>
              </thead>
              <tbody>
                {evidence.map((c) => (
                  <tr>
                    <td>
                      {c.name}
                      {c.anv ? <> (as <em>{c.anv}</em>)</> : null}
                      {c.track_position ? (
                        <>
                          {' '}
                          <code>{c.track_position}</code>
                        </>
                      ) : null}
                    </td>
                    <td>{scopeLabel[c.credit_scope]}</td>
                    <td>{c.role_text ?? '—'}</td>
                    <td>
                      <span class="tag tag--linked">#{c.artist_id} · linked</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {nonLinked.length > 0 && (
            <p class="hop__release" style="margin-top:10px">
              Also on this release as <strong>evidence only</strong> (not a playable identity):{' '}
              {nonLinked.map((c, i) => (
                <>
                  {i > 0 ? ', ' : ''}
                  <span class="tag tag--unlinked">{c.name}</span>
                  {c.role_text ? ` — ${c.role_text}` : ''}
                </>
              ))}
            </p>
          )}
        </div>
      );
    })
  }
</article>
