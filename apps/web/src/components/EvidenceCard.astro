---
import type { AlbumV2, Artist, Credit, EvidenceRelease, PathV2 } from '../data/challenge';

interface Props {
  path: PathV2;
  releases: EvidenceRelease[];
  artists: Artist[];
  albums: AlbumV2[];
  hidden?: boolean;
  id?: string;
}

const { path, releases, artists, albums, hidden = false, id } = Astro.props;

const releaseById = new Map(releases.map((r) => [r.release_id, r]));
const nameById = new Map(artists.map((a) => [a.artist_id, a.name]));
const albumById = new Map(albums.map((a) => [a.id, a]));

const displayName = (id: number) => nameById.get(id) ?? `Artist ${id}`;
const scopeLabel: Record<Credit['credit_scope'], string> = {
  release_artist: 'release artist',
  release_credit: 'release credit',
  track_artist: 'track artist',
  track_credit: 'track credit',
};

const fromAlbum = albumById.get(path.from_album_id);
const toAlbum = albumById.get(path.to_album_id);
---

<article class="evidence-card" id={id} data-path-id={path.id} hidden={hidden}>
  <div class="evidence-card__summary">
    <div class="evidence-card__endpoint">
      {
        fromAlbum?.cover_image && (
          <img
            class="cover-thumb"
            src={fromAlbum.cover_image.uri150}
            width="56"
            height="56"
            loading="lazy"
            alt=""
          />
        )
      }
      <span>{fromAlbum?.title ?? path.from_album_id}</span>
    </div>
    <span class="arrow" aria-hidden="true">→</span>
    <div class="evidence-card__endpoint">
      {
        toAlbum?.cover_image && (
          <img
            class="cover-thumb"
            src={toAlbum.cover_image.uri150}
            width="56"
            height="56"
            loading="lazy"
            alt=""
          />
        )
      }
      <span>{toAlbum?.title ?? path.to_album_id}</span>
    </div>
  </div>
  <p class="path-card__sub">{path.description}</p>

  {
    path.hops.map((hop, index) => {
      const release = releaseById.get(hop.release_id);
      if (!release) return null;
      const endpoints = [hop.artist_a_id, hop.artist_b_id];
      const evidence = release.credits.filter(
        (c) => c.artist_id !== null && endpoints.includes(c.artist_id),
      );
      const nonLinked = release.credits.filter((c) => !c.is_linked);
      return (
        <div class="hop">
          <div class="hop__head">
            <div class="hop__head-text">
              <p class="hop__title">
                Hop {index + 1}: {displayName(hop.artist_a_id)} and {displayName(hop.artist_b_id)}
              </p>
              <p class="hop__release">
                both credited on <strong>{release.title}</strong>
                {release.released ? ` (${release.released}` : ''}
                {release.released && release.country
                  ? `, ${release.country})`
                  : release.released
                    ? ')'
                    : ''}
                {' · '}
                <a href={release.source_url} rel="nofollow noopener">source</a>
              </p>
            </div>
          </div>
          <div class="evidence">
            <table>
              <caption>Release {release.release_id} · evidence</caption>
              <thead>
                <tr>
                  <th scope="col">Credited as</th>
                  <th scope="col">Scope</th>
                  <th scope="col">Role</th>
                  <th scope="col">Identity</th>
                </tr>
              </thead>
              <tbody>
                {evidence.map((c) => (
                  <tr>
                    <td>
                      {c.name}
                      {c.anv ? <> (as <em>{c.anv}</em>)</> : null}
                      {c.track_position ? (
                        <>
                          {' '}
                          <code>{c.track_position}</code>
                        </>
                      ) : null}
                    </td>
                    <td>{scopeLabel[c.credit_scope]}</td>
                    <td>{c.role_text ?? '—'}</td>
                    <td>
                      <span class="tag tag--linked">#{c.artist_id} · linked</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {nonLinked.length > 0 && (
            <p class="hop__release" style="margin-top:10px">
              Also on this release as <strong>evidence only</strong> (not a playable identity):{' '}
              {nonLinked.map((c, i) => (
                <>
                  {i > 0 ? ', ' : ''}
                  <span class="tag tag--unlinked">{c.name}</span>
                  {c.role_text ? ` — ${c.role_text}` : ''}
                </>
              ))}
            </p>
          )}
        </div>
      );
    })
  }
</article>
