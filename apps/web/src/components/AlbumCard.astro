---
import type { AlbumV2 } from '../data/challenge';
import { coverFor } from '../data/albumArt';

interface Props {
  album: AlbumV2;
}

const { album } = Astro.props;
// Presentation art comes from the album-art registry (ADR 0045), never from
// frozen artifact fields; fall back to any legacy embedded cover, then to the
// polished placeholder.
const cover = coverFor(album.id) ?? album.cover_image;
---

<a class="album-card" href={`/albums/${album.id}/`}>
  {
    cover ? (
      <img
        class="album-card__cover"
        src={cover.uri150}
        width="150"
        height="150"
        loading="lazy"
        alt={`Cover art for ${album.title}`}
        data-art-fallback="disc"
      />
    ) : (
      <span class="album-card__placeholder" aria-hidden="true">
        <span class="album-card__placeholder-disc" />
      </span>
    )
  }
  <span class="album-card__title">{album.title}</span>
  <span class="album-card__meta">
    {album.artist}
    {album.year ? ` · ${album.year}` : ''}
  </span>
</a>
