---
// A play-hub entry styled as a record-shop divider card. `status` controls
// availability: live modes link out; coming modes render as a non-interactive
// card with an honest label (never a dead link).
interface Props {
  title: string;
  description: string;
  href: string;
  kicker: string;
  tone?: 'teal' | 'rust' | 'gold';
  status: 'live' | 'coming';
  note?: string;
}

const { title, description, href, kicker, tone = 'teal', status, note } = Astro.props;
---

{
  status === 'live' ? (
    <a class="mode-card" data-tone={tone} data-testid="mode-card" data-mode-status="live" href={href}>
      <span class="mode-card__kicker">{kicker}</span>
      <h3 class="mode-card__title">{title}</h3>
      <p class="mode-card__body">{description}</p>
      {note && <p class="mode-card__note">{note}</p>}
    </a>
  ) : (
    <div class="mode-card mode-card--coming" data-tone={tone} data-testid="mode-card" data-mode-status="coming">
      <span class="mode-card__kicker">{kicker}</span>
      <h3 class="mode-card__title">{title}</h3>
      <p class="mode-card__body">{description}</p>
      <p class="mode-card__note">{note ?? 'In the works — not playable yet.'}</p>
    </div>
  )
}
