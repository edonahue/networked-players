# Copy to local/dask.env (git-ignored) and edit. Never commit local/dask.env
# -- it carries a real filesystem path and an access token, both private per
# docs/PUBLIC_PRIVATE_BOUNDARY.md.

# Required. Generate one: python3 -c "import secrets; print(secrets.token_hex(24))"
JUPYTER_TOKEN=CHANGEME

# Required. Absolute path to real ingested Discogs Parquet output on THIS
# host (see docs/DISCOGS_INGESTION.md), read-only-mounted into Jupyter and
# the local Dask worker(s) for notebooks/02-explore-real-discogs-catalog.ipynb.
# If you haven't run a real ingest yet, point this at an empty directory --
# notebooks 00/01 (synthetic data) still work fine.
DISCOGS_PROCESSED_DIR=/CHANGE/ME/local/processed/discogs

# Only needed on the optional build node's docker-compose.dask-worker-remote.yml
# -- the coordination host's real LAN address.
DASK_SCHEDULER_ADDRESS=192.0.2.10

# Optional. Default snapshot date for notebooks/02-explore-real-discogs-catalog.ipynb
# (matches scripts/profile-discogs-dataset.sh's SNAPSHOT convention). Leave
# unset if you haven't run a real ingest yet -- notebooks 00/01 don't need it.
SNAPSHOT=20260601
