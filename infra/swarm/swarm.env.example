# Copy to local/swarm.env (git-ignored) and set the real value.
# Never commit local/swarm.env -- it carries the real LAN address of the
# coordination host, which is private per docs/PUBLIC_PRIVATE_BOUNDARY.md.
#
# Used by infra/swarm/init-swarm-manager.sh as --advertise-addr for
# `docker swarm init`.
ADVERTISE_ADDR=192.0.2.10
