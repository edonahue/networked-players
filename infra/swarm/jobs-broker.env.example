# Copy to local/jobs-broker.env (git-ignored) or let deploy-jobs-broker.sh
# generate it for you on first run. Never commit local/jobs-broker.env -- it
# carries the real LAN address of the coordination host and a real password,
# both private per docs/PUBLIC_PRIVATE_BOUNDARY.md.
JOBS_BROKER_BIND_IP=192.0.2.10
JOBS_BROKER_PORT=6380
JOBS_BROKER_PASSWORD=CHANGEME
JOBS_BROKER_DATA_DIR=/srv/networked-players/jobs-broker
