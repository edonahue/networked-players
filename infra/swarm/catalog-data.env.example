# Copy to local/catalog-data.env (git-ignored) or let deploy-catalog-data.sh
# generate it for you on first run. Never commit local/catalog-data.env -- it
# carries the real LAN address of the coordination host and the real dataset
# path, both private per docs/PUBLIC_PRIVATE_BOUNDARY.md.
CATALOG_DATA_BIND_IP=192.0.2.10
CATALOG_DATA_PORT=8791
CATALOG_DATA_DIR=/CHANGE/ME/local/processed
